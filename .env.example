# ---------------------------------------------------------------------------
# Canvas — required by download_syllabi.py
# ---------------------------------------------------------------------------
# Create a token at: https://canvas.uw.edu/profile/settings  ->  + New Access Token
CANVAS_API_TOKEN=

# Canvas base URL. Defaults to the UW instance if left unset.
# CANVAS_BASE_URL=https://canvas.uw.edu

# ---------------------------------------------------------------------------
# GitHub — required by upload_to_github.py
# ---------------------------------------------------------------------------
# Fine-grained PAT with "Contents: Read and write" on the target repo only.
GITHUB_TOKEN=

# Target repository as owner/name.
GITHUB_REPO=pisanuw/canvas-syllabus-downloader

# Branch to commit to. Defaults to main if left unset.
# GITHUB_BRANCH=main
